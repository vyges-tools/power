UNITS DISTANCE MICRONS 1000 ;
COMPONENTS 5 ;
- clkbuf CLKBUF + PLACED ( 500 100 ) N ;
- u0 INV + PLACED ( 2600 100 ) N ;
- u1 BUF + PLACED ( 5100 100 ) N ;
- ff0 DFF + PLACED ( 7600 100 ) N ;
- ff1 DFF + PLACED ( 9500 100 ) N ;
END COMPONENTS
SPECIALNETS 1 ;
- VPWR
  + USE POWER
  + ROUTED met5 1000 ( 0 0 ) M ( 0 10000 )
    NEW met4 1000 ( 0 0 ) ( 2500 0 ) ( 5000 0 ) ( 7500 0 ) ( 10000 0 )
 ;
END SPECIALNETS
